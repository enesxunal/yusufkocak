# Google Analytics 4 ölçüm kimliği (Admin > Veri akışları > G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML etiketi doğrulama kodu (content değeri)
# Örnek: meta name="google-site-verification" content="abc123..." → sadece abc123... yazın
NEXT_PUBLIC_GSC_VERIFICATION=

# --- GOOGLE ADS DÖNÜŞÜM TAKİBİ ---
# Google Ads dönüşüm kimliği. Ads > Araçlar > Dönüşümler ekranındaki "AW-" ile başlayan kod.
# Örnek: AW-123456789
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Her dönüşüm işleminin "etiketi" (conversion label). Ads'te dönüşüm oluşturunca verilir.
# send_to değeri "AW-123456789/AbC-D_efg" formatında olur; sadece "/" sonrası kısmı buraya yazın.
# WhatsApp'a tıklama / mesaj gönderme dönüşümü:
NEXT_PUBLIC_ADS_LABEL_WHATSAPP=
# Telefonla arama (tel: linkine tıklama) dönüşümü:
NEXT_PUBLIC_ADS_LABEL_PHONE=
# Ücretsiz ön görüşme formu gönderimi dönüşümü:
NEXT_PUBLIC_ADS_LABEL_APPOINTMENT=
